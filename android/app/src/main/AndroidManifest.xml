<?xml version="1.0" encoding="utf-8"?>
<!--
    Thai Voice Translator v2 — Android Manifest
    =============================================
    Module 9-11: System audio capture (AudioPlaybackCapture),
    Foreground Service, WebSocket client, and audio playback
    with Audio Focus Ducking.

    Architecture: v2 Android (system audio capture) + v1 Backend (free)

    Permissions:
      - FOREGROUND_SERVICE              → Required for persistent capture
      - FOREGROUND_SERVICE_MEDIA_PROJECTION → Foreground service type
      - POST_NOTIFICATIONS              → Required on Android 13+
      - INTERNET                        → WebSocket connection
      - ACCESS_NETWORK_STATE            → Connectivity checks
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ==================================================================
         Foreground Service Permissions
         ================================================================== -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Notification permission — required on Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ==================================================================
         Network Permissions (normal — auto-granted)
         ================================================================== -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ==================================================================
         Hardware / Feature Requirements
         ================================================================== -->

    <!-- AudioPlaybackCapture requires Android 10+ (API 29) -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar"
        android:usesCleartextTraffic="true">

        <!--
            MainActivity — entry point: MediaProjection consent + status UI
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            AudioCaptureService — Foreground Service for system audio capture.
            foregroundServiceType="mediaProjection" is required on Android 14+ (API 34)
            for services that use MediaProjection tokens.
        -->
        <service
            android:name=".capture.AudioCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

    </application>

</manifest>
