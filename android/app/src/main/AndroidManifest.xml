<?xml version="1.0" encoding="utf-8"?>
<!--
    Thai Voice Translator — Android Manifest
    =========================================
    Module 9-11: Audio recording, WebSocket, and audio playback.

    Permissions required:
      - RECORD_AUDIO   → Module 9  (AudioRecorder.kt)
      - INTERNET       → Module 10 (TranslatorWebSocketClient.kt)

    These are declared here so the app can be built and tested immediately
    after opening in Android Studio.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.thaivoice.translator">

    <!-- ==================================================================
         Dangerous Permissions (require runtime request on API 23+)
         See AudioRecorder.kt → hasRecordPermission() helper
         ================================================================== -->

    <!-- Microphone — needed by AudioRecorder (Module 9) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ==================================================================
         Normal Permissions (granted automatically at install time)
         ================================================================== -->

    <!-- WebSocket connection to backend (Module 10) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Good practice: declare network state for connectivity checks -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <!--
            Main Activity — will be created when you open this project
            in Android Studio. Replace ".MainActivity" with your actual
            Activity class once created.

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        -->

    </application>

</manifest>
