# Thai Voice Translator — Environment Variables
# =============================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# .env is already in .gitignore.

# ── Security (Module 7) ────────────────────────────────────────────────
# Shared secret between Android app and backend.
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
BACKEND_API_KEY=k3EOTM10GxevuDLUHj7g7TwZ16nfiq8bBGqEG0hAMoA

# ── Translation API (Module 4) ─────────────────────────────────────────
# OpenAI-compatible API key (OpenAI, Gemini via OpenAI endpoint, etc.)
TRANSLATE_API_KEY=your-gemini-api-key-here

# Gemini API endpoint (free tier: 1,500 req/day)
TRANSLATE_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Gemini fast model — ideal for real-time translation
TRANSLATE_MODEL=gemini-2.0-flash

# ── Development ────────────────────────────────────────────────────────
# Set to 1 to skip Whisper model loading on Windows (ctranslate2 segfault)
# WHISPER_DISABLED=1

# ── Rate Limiting (Module 7) ───────────────────────────────────────────
# Max WebSocket/HTTP connections per IP per 60-second window (default: 30)
# RATE_LIMIT_PER_MINUTE=30
